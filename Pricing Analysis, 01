# Part 2: ROCm Friction Analysis
# Data sourced from AMD ROCm GitHub issues and developer complaints

rocm_issues = {
    'Issue Category': [
        'CUDA Compatibility/Migration',
        'Installation & Setup',
        'Performance Gaps vs CUDA',
        'Framework Support (PyTorch/TF)',
        'Multi-GPU Scaling',
        'Documentation Gaps',
        'Driver Stability'
    ],
    'Severity': ['Critical', 'High', 'Critical', 'High', 'Medium', 'Medium', 'High'],
    'Churn_Risk': [9, 7, 9, 8, 6, 5, 8],  # 1-10 scale, 10 = highest churn risk
    'Typical_Discovery_Month': [2, 1, 2, 1, 3, 1, 2]  # When customer typically hits this
}

df_rocm = pd.DataFrame(rocm_issues)

fig, axes = plt.subplots(1, 2, figsize=(14, 6))

# Chart 1: Churn risk by issue type
colors = ['#E8472A' if r >= 8 else '#F5A623' if r >= 6 else '#4A90D9' 
          for r in df_rocm['Churn_Risk']]
axes[0].barh(df_rocm['Issue Category'], df_rocm['Churn_Risk'], color=colors)
axes[0].set_xlabel('Churn Risk Score (1-10)')
axes[0].set_title('ROCm Issue Categories by Churn Risk', fontweight='bold')
axes[0].axvline(x=7, color='red', linestyle='--', alpha=0.7, label='High Risk Threshold')
axes[0].legend()

# Chart 2: When customers discover issues
axes[1].scatter(df_rocm['Typical_Discovery_Month'], df_rocm['Churn_Risk'], 
                s=200, color=colors, zorder=5)
for i, row in df_rocm.iterrows():
    axes[1].annotate(row['Issue Category'][:20], 
                    (row['Typical_Discovery_Month'], row['Churn_Risk']),
                    textcoords="offset points", xytext=(5, 5), fontsize=7)
axes[1].set_xlabel('Month Customer Typically Discovers Issue')
axes[1].set_ylabel('Churn Risk Score')
axes[1].set_title('Churn Risk vs Discovery Timeline', fontweight='bold')
axes[1].set_xlim(0, 4)

plt.suptitle('ROCm Friction: When and How Customers Churn', 
             fontsize=14, fontweight='bold')
plt.tight_layout()
plt.savefig('../visualizations/rocm_friction.png', dpi=150, bbox_inches='tight')
plt.show()

print("\nKey insight: Highest churn risk issues cluster in months 1-2")
print("This is TensorWave's critical intervention window")
